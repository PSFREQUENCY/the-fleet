# THE FLEET — Environment variables
# Copy to .env and never commit it

# Required
FLEET_TOKEN=your_telegram_bot_token_from_BotFather

# Optional — enables AES-256-GCM state encryption (64 hex chars = 32 bytes)
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
FLEET_KEY=

# Optional — Venice AI private inference (crystallize, analyze, reason)
VENICE_API_KEY=

# Tuning
FLEET_DB=fleet.enc          # encrypted state file path
HEARTBEAT_SEC=300           # memory decay + save interval (seconds)
SLEEP_SEC=3600              # deep consolidation + market update interval
MAX_STM=200                 # max short-term memory nodes before eviction
DECAY_RATE=0.02             # memory strength lost per heartbeat
